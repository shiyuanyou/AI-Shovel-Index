# Runtime data
# DB is committed to repo so GitHub Actions can accumulate history across runs.
# Output (PNG/txt) is ephemeral — uploaded as artifacts, not committed.
data/*.db-journal
data/*.db-shm
data/*.db-wal
output/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Test artifacts (keep fixtures/output for visual inspection during dev,
# but exclude from repo to avoid binary bloat)
tests/fixtures/output/*.png
tests/fixtures/output/*.txt
tests/fixtures/preview/*.png

# Editors
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Node / Tailwind build
node_modules/
# compiled CSS is committed so Python renderer works without running npm
# (re-generate with: npm run build:css)


